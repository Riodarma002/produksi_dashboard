# Azure AD / Microsoft Graph API Credentials
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to version control!

# Azure Tenant ID
AZURE_TENANT_ID=your_tenant_id_here

# Azure Client ID (Application ID)
AZURE_CLIENT_ID=your_client_id_here

# Azure Client Secret
# Generate this in Azure Portal > App Registrations > Certificates & secrets
AZURE_CLIENT_SECRET=your_client_secret_here

# OneDrive Excel File IDs (Optional - if using direct file ID approach)
# Leave empty if using share links
FILE_IDS_DB_HOURLY=
FILE_IDS_PLAN_HOURLY=
